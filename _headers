# Service Worker — must be served with these headers for cross-origin scope to work
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

# Web manifest
/site.webmanifest
  Content-Type: application/manifest+json
  Cache-Control: no-cache

# PWA install script — never cache so updates apply immediately
/pwa-install.js
  Cache-Control: no-cache, no-store, must-revalidate

# Offline page
/offline.html
  Cache-Control: no-cache

# Icons — long cache, they change rarely
/icons/*
  Cache-Control: public, max-age=604800, immutable

# Sitemap XSL stylesheet — must serve as text/xsl or browsers silently
# ignore the <?xml-stylesheet?> link in sitemap.xml and just show raw XML
/sitemap.xsl
  Content-Type: text/xsl; charset=utf-8

# Sitemap XML — explicit content type for correctness
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
